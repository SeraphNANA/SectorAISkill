# SectorAISkill - AI岗位工具配置分析系统

# ==================== 爬虫配置 ====================
# 搜索关键词，多个用逗号分隔
SPIDER_KEYWORDS=AI设计总监,AI视觉设计师,AI创意总监

# 爬取页数（每页约15-30个岗位）
SPIDER_PAGE_COUNT=3

# 爬取超时时间（毫秒）
SPIDER_TIMEOUT=30000

# 目标城市（留空表示全国）
# SPIDER_CITY=北京

# 招聘平台: boss( Boss直聘 ) | zhaopin( 智联招聘 )
SPIDER_PLATFORM=boss

# ==================== AI工具词库配置 ====================
# 核心AI工具关键词，用于提取和统计
AI_TOOL_KEYWORDS=Midjourney,Stable Diffusion,DALL·E,Firefly,Runway,Pika,Sora,剪映AI,可灵,HeyGen,Figma AI,Canva AI,Nano Banana,Lovart,Bolt,Pinterest

# ==================== 岗位筛选配置 ====================
# 最小正向关键词匹配数
FILTER_MIN_POSITIVE=1

# 最小岗位描述长度
FILTER_MIN_JD_LENGTH=50

# 岗位层级定义
POSITION_LEVELS=设计总监,设计主管,设计专员

# ==================== 公司规模配置 ====================
# 目标公司规模: 小型 | 中型 | 大型
COMPANY_SCALE=中型

# ==================== 输出配置 ====================
# 输出目录
OUTPUT_DIR=output

# 输出格式: excel | json | both
OUTPUT_FORMAT=excel

# ==================== 浏览器配置 ====================
# 无头模式: true | false
HEADLESS=false

# 用户数据目录（保持登录状态）
USER_DATA_DIR=./user_data

# ==================== 高级配置 ====================
# 请求间隔（毫秒）
REQUEST_DELAY=2000

# 最大重试次数
MAX_RETRIES=3

# 详细日志: true | false
VERBOSE=false
